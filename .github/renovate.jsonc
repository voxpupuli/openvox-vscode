{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  // add labels to all renovate PRs
  "addLabels": [
    "dependencies",
    "renovate"
  ],
  // assign PRs to code owners
  "assigneesFromCodeOwners": true,
  "customManagers": [
    {
      // Keep the vendored openvox-editor-services gem version visible in package.json
      // while still letting Renovate track updates from RubyGems.
      "customType": "regex",
      "managerFilePatterns": [
        "/^package\\.json$/"
      ],
      "matchStrings": [
        "\"openvox-editor-services\"\\s*:\\s*\"(?<currentValue>[^\"]+)\""
      ],
      "depNameTemplate": "openvox-editor-services",
      "datasourceTemplate": "rubygems"
    }
  ]
}
